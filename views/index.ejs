<%- include("partials/header", { title: "Home" }) %>



<main class="page-shell home-page">
  <div class="container">
    <section class="hero-card">
      <% if (user) { %>
  <li style="font-size: 20px; color: rgb(15, 208, 15); font-weight: 700;">You are logged in</li>
<% } else { %>
  <li style="font-size: 20px; color: rgb(223, 12, 12); font-weight: 700;">You are logged out</li>
<% } %>
      <h1>⚡ URL Shortener</h1>
      <p class="subtitle">Create clean short links in seconds.</p>

      <% if (error) { %>
        <script>
          alert("<%= error %>");
        </script>
      <% } %>

      <form action="/" method="POST" class="form-card">
        <div class="input-group">
          <label for="url">Enter URL</label>
          <input
            id="url"
            type="url"
            name="url"
            placeholder="https://example.com"
            required
          />
        </div>

        <div class="input-group">
          <label for="shortCode">Custom Short Code (optional)</label>
          <input
            id="shortCode"
            type="text"
            name="shortCode"
            placeholder="abc123"
          />
        </div>

                  <% if (errors && errors.length > 0) { %>
  <div class="error-box">
    <ul>
      <% errors.forEach(error => { %>
        <li><%= error %></li>
      <% }) %>
    </ul>
  </div>
<% } %>

        <button type="submit" class="btn-primary">Shorten URL</button>
      </form>
    </section>

    <section class="card-section">
      <h2>📌 Shortened URLs</h2>

      <% if (links.length === 0) { %>
        <p class="empty">No URLs created yet.</p>
      <% } else { %>
        <ul id="shortened-urls" class="url-list">
          <% links.forEach(({ url, short_code }) => { %>
            <li class="url-card">
              <a href="/<%= short_code %>" target="_blank" class="short-link">
                <%= protocol %>://<%= host %>/<%= short_code %>
              </a>
              <p class="original-url"><%= url %></p>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </section>
  </div>
</main>

<%- include("partials/footer") %>