<%- include("partials/header", { title: "Home" }) %>

<% if (access_token) { %>
  <h2>You are logged in</h2>
<% } else { %>
  <h2>You are logged out</h2>
<% } %>

<main class="page-shell home-page">
  <div class="container">
    <section class="hero-card">
      <h1>⚡ URL Shortener</h1>
      <p class="subtitle">Create clean short links in seconds.</p>

      <% if (error) { %>
        <script>
          alert("<%= error %>");
        </script>
      <% } %>

      <form action="/" method="POST" class="form-card">
        <div class="input-group">
          <label for="url">Enter URL</label>
          <input
            id="url"
            type="url"
            name="url"
            placeholder="https://example.com"
            required
          />
        </div>

        <div class="input-group">
          <label for="shortCode">Custom Short Code (optional)</label>
          <input
            id="shortCode"
            type="text"
            name="shortCode"
            placeholder="abc123"
          />
        </div>

        <button type="submit" class="btn-primary">Shorten URL</button>
      </form>
    </section>

    <section class="card-section">
      <h2>📌 Shortened URLs</h2>

      <% if (links.length === 0) { %>
        <p class="empty">No URLs created yet.</p>
      <% } else { %>
        <ul id="shortened-urls" class="url-list">
          <% links.forEach(({ url, short_code }) => { %>
            <li class="url-card">
              <a href="/<%= short_code %>" target="_blank" class="short-link">
                <%= protocol %>://<%= host %>/<%= short_code %>
              </a>
              <p class="original-url"><%= url %></p>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </section>
  </div>
</main>

<%- include("partials/footer") %>