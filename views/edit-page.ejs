<%- include("partials/header", { title: "edit-page" }) %>



<main class="page-shell home-page">
  <div class="container">
    <section class="hero-card">
      <% if (user) { %>
  <li style="font-size: 20px; color: rgb(15, 208, 15); font-weight: 700;">You are logged in</li>
<% } else { %>
  <li style="font-size: 20px; color: rgb(223, 12, 12); font-weight: 700;">You are logged out</li>
<% } %>
      <h1>⚡ URL Shortener</h1>
      <p class="subtitle">update clean short links in seconds.</p>

      <% if (error) { %>
        <script>
          alert("<%= error %>");
        </script>
      <% } %>

      <form action="/edit/<%= id %>" method="post" class="form-card">
        <div class="input-group">
          <label for="url">Enter URL</label>
          <input
            id="url"
            type="url"
            name="url"
            value="<%= url %>"
            placeholder="https://example.com"
            required
          />
        </div>

        <div class="input-group">
          <label for="shortCode">Custom Short Code (optional)</label>
          <input
            id="shortCode"
            type="text"
            name="shortCode"
            value="<%= shortCode %>"
            placeholder="abc123"
          />
        </div>

                  <% if (errors && errors.length > 0) { %>
  <div class="error-box">
    <ul>
      <% errors.forEach(error => { %>
        <li><%= error %></li>
      <% }) %>
    </ul>
  </div>
<% } %>

        <button type="submit" value="update" class="btn-primary">update</button>
      </form>
    </section>

  </div>
</main>

<%- include("partials/footer") %>